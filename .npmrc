# ── pnpm security configuration ──────────────────────────

# Only allow explicitly listed packages to run lifecycle scripts
only-built-dependencies[]=sharp

# Fail on missing peer dependencies
strict-peer-dependencies=true

# Do not auto-install peer dependencies
auto-install-peers=false

# Fail if Node.js version doesn't satisfy engine requirements
engine-strict=true

# Verify package integrity checksums
resolution-mode=highest

# Use frozen lockfile in CI to detect unexpected changes
# frozen-lockfile=true

# Prevent dangling symlinks
node-sync-method=copy

# Avoid unexpected network requests
prefer-offline=false


